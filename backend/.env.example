MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_jwt_secret
PORT=5000

# Gmail SMTP credentials (use Gmail App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_FROM=Road Complaint <your-email@gmail.com>

# Preferred cloud option: Resend (HTTPS API over port 443)
# If set, backend sends OTP via Resend first and falls back to SMTP.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Road Complaint <onboarding@resend.dev>

# Frontend origins allowed by CORS
FRONTEND_URL=http://localhost:3001
FRONTEND_URL_2=https://your-frontend.onrender.com

# Optional OTP secret fallback
OTP_SECRET=replace_with_random_secret
