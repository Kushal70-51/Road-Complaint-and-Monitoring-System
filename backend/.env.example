MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_jwt_secret
PORT=5000

# Gmail SMTP (use 16-char App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_FROM=Road Project <your-email@gmail.com>

# Optional compatibility aliases
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=Road Project <your-email@gmail.com>

# Optional OTP secret fallback
OTP_SECRET=replace_with_random_secret
