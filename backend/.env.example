MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_jwt_secret
PORT=5000

# Brevo SMTP relay credentials
EMAIL_USER=your_brevo_login_email
EMAIL_PASS=your_brevo_smtp_key
SMTP_FROM=Road Complaint <your_verified_sender_email>

# Frontend origins allowed by CORS
FRONTEND_URL=http://localhost:3001
FRONTEND_URL_2=https://your-frontend.onrender.com

# Optional OTP secret fallback
OTP_SECRET=replace_with_random_secret
